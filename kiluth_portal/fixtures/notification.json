  "message": "<p>Hi {{ doc.employee_name or doc.employee }},</p>\n<p>HR has prepared an Equipment Loan Agreement for you. Please review the assets and terms, then click <b>I Acknowledge</b> on the form to complete the loan.</p>\n<ul>\n  <li><b>Agreement:</b> {{ doc.name }}</li>\n  <li><b>Assets:</b> {{ doc.assets|length }}</li>\n  {% if doc.accessories %}<li><b>Accessories:</b> {{ doc.accessories }}</li>{% endif %}\n</ul>\n<p>{{ frappe.utils.get_link_to_form(doc.doctype, doc.name, 'Review & acknowledge') }}</p>\n<p style=\"color:#888;font-size:0.9em\">Your acknowledgment is logged with your user account and timestamp as an audit trail. If anything looks wrong, reply to this email and HR will adjust.</p>",
